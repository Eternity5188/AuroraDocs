# ============================================================
# AuroraDocs 后端配置示例
# 
# 使用说明：
# 1. Docker 部署: 运行 python scripts/setup_backend.py
# 2. 本地部署: 复制此文件为 .env，然后编辑配置值
# ============================================================

# ===== 数据库配置 =====
# Docker 部署请使用: postgresql://user:password@postgres:5432/assignment_ai
# 本地部署请使用本地主机名或 IP
# 格式: postgresql://[用户名]:[密码]@[主机]:[端口]/[数据库名]
DATABASE_URL=postgresql://user:password@postgres:5432/assignment_ai

# ===== Redis 缓存 =====
# Docker 部署请使用: redis://redis:6379/0
# 本地部署请使用本地地址
# 用于缓存和任务队列
REDIS_URL=redis://redis:6379/0

# ===== 文件存储 (MinIO) =====
# Docker 部署请使用: minio:9000
# 本地部署请使用本地地址
# 使用 MinIO 存储样例文档和生成结果
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# ===== JWT 安全认证 =====
# SECRET_KEY: 用于 token 签名的密钥（生成方式见下文）
# 生成安全密钥: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== AI 模型配置 =====
# MODEL_BASE_PATH: 模型文件存储目录
# Docker 部署: /data/models
# 本地部署: ./models 或完整路径
MODEL_BASE_PATH=/data/models

# SAMPLE_UPLOAD_PATH: 用户上传的样例文档存储目录
# Docker 部署: /data/samples
# 本地部署: ./data/samples 或完整路径
SAMPLE_UPLOAD_PATH=/data/samples

# vLLM 推理引擎配置
VLLM_HOST=localhost
VLLM_PORT=8001

# ===== CORS 跨域配置 =====
# 允许访问 API 的前端地址（逗号分隔）
# 开发环境: http://localhost:5173,http://127.0.0.1:5173
# 生产环境: https://your-domain.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===== 前端配置 =====
# 前端访问的 API 基础地址
# 开发环境: http://localhost:8000/api
# 生产环境: https://your-domain.com/api
VITE_API_BASE_URL=http://localhost:8000/api
